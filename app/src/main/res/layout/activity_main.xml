<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/cyber_bg">

    <!-- Status Banner Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cvStatusBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="@color/cyber_card"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:id="@+id/tvStatusBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="@string/status_local_offline"
            android:textStyle="bold"
            android:textColor="@color/cyber_secondary"
            android:gravity="center"/>
    </androidx.cardview.widget.CardView>

    <!-- Header -->
    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:src="@drawable/ic_launcher_foreground"
        app:layout_constraintTop_toBottomOf="@id/cvStatusBanner"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/cyber_primary"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="@id/ivLogo"
        app:layout_constraintBottom_toBottomOf="@id/ivLogo"
        app:layout_constraintStart_toEndOf="@id/ivLogo"/>

    <!-- Nickname Input -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilNickname"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:boxStrokeColor="@color/cyber_primary"
        android:textColorHint="@color/cyber_text"
        app:boxBackgroundColor="@color/cyber_card"
        app:layout_constraintTop_toBottomOf="@id/ivLogo">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etNickname"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/custom_nickname"
            android:textColor="@color/cyber_text"/>
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Controls -->
    <LinearLayout
        android:id="@+id/llControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/tilNickname">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAdvertise"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/advertise"
            android:layout_marginEnd="8dp"
            app:backgroundTint="@color/cyber_primary"
            android:textColor="@color/black" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDiscover"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/discover"
            android:layout_marginStart="8dp"
            app:backgroundTint="@color/cyber_secondary"
            android:textColor="@color/white" />
    </LinearLayout>

        <!-- QR Controls -->
        <LinearLayout
            android:id="@+id/llQrControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/llControls">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnShowQr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/show_qr_profile"
                android:layout_marginEnd="8dp"
                app:backgroundTint="#2E2E2E"
                android:textColor="@color/cyber_primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnScanQr"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/scan_qr_profile"
                android:layout_marginStart="8dp"
                app:backgroundTint="#2E2E2E"
                android:textColor="@color/cyber_secondary" />
        </LinearLayout>

    <FrameLayout
        android:id="@+id/flContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/llQrControls"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">
        
        <LinearLayout
            android:id="@+id/viewDiscover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/recent_peers"
                android:textColor="@color/cyber_primary"
                android:textStyle="bold"/>
            
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentPeers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/discovered_devices"
                android:textColor="@color/cyber_primary"
                android:textStyle="bold"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDevices"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
        
        <LinearLayout
            android:id="@+id/viewGlobal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone"
            android:padding="16dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/global_chat_feature"
                android:textColor="@color/cyber_text"
                android:textAlignment="center"/>
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:menu="@menu/bottom_nav_menu"
        android:background="@color/cyber_card"
        app:itemIconTint="@color/cyber_primary"
        app:itemTextColor="@color/cyber_text"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
